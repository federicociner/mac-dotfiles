# Base
shell-integration = none

# Theme - swap between: catppuccin-frappe, catppuccin-mocha, catppuccin-macchiato, catppuccin-latte
theme = catppuccin-frappe

# Appearance
font-size = 16
window-padding-x = 12
window-padding-y = 12
window-padding-balance = true

# Font
font-family = "JetBrains Mono"
font-family-bold = "JetBrains Mono Bold"
font-family-italic = "JetBrains Mono Italic"
font-family-bold-italic = "JetBrains Mono Bold Italic"

# Quick terminal
keybind = global:cmd+grave_accent=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-size = 50%,75%
